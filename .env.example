# Salin file ini ke `.env` lalu sesuaikan bila perlu:  cp .env.example .env
# Nilai default di bawah aman untuk pemakaian LOKAL. Untuk non-lokal, GANTI password.

# ── ClickHouse (storage permanen OHLCV) ───────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=tradingch123
CLICKHOUSE_DB=market

# ── PostgreSQL (journal, portfolio, transaksi) ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=trading
POSTGRES_PASSWORD=tradingpass123
POSTGRES_DB=tradingdb

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Pipeline TCP (Yahoo → TCP → Kafka) ────────────────────────────────────────
TCP_HOST=ingestion
TCP_PORT=9009

# ── Ingestion (yFinance) ──────────────────────────────────────────────────────
POLL_INTERVAL=300                  # interval poll yFinance (detik)
CHART_INTERVALS=5m,15m,1h,1d,1wk   # timeframe yang di-fetch
# Sumber daftar emiten IDX (auto-fetch saat startup)
UNIVERSE_URL=https://raw.githubusercontent.com/wildangunawan/Dataset-Saham-IDX/master/List%20Emiten/all.csv
CHUNK_SIZE=60                      # ticker per batch yf.download (hindari rate-limit)
REBACKFILL_HOURS=6                 # re-backfill penuh tiap N jam (self-heal)
MAX_SYMBOLS=0                      # 0 = semua ~951 emiten; >0 = batasi (subset)
